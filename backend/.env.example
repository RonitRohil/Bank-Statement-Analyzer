# Flask settings
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=true

# CORS — comma-separated or JSON array of allowed origins
CORS_URLS=http://localhost:3000

# File upload
MAX_UPLOAD_SIZE=20971520   # 20 MB in bytes

# Optional: Pennyless bank account verification API
INTEGRATION_URL=
INTEGRATION_AUTH=
